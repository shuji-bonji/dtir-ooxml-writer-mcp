{
  "name": "@shuji-bonji/dtir-ooxml-writer-mcp",
  "version": "0.0.1",
  "description": "MCP server: patch a .docx from a translated DTIR by id, preserving structure (collapse mode)",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./writer": "./dist/writer.js"
  },
  "bin": {
    "dtir-ooxml-writer-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:roundtrip": "tsx test/roundtrip.ts",
    "test:torture": "tsx test/torture-roundtrip.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "docx",
    "ooxml",
    "translation",
    "dtir"
  ],
  "author": "shuji-bonji",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "@shuji-bonji/doc-translation-ir": "file:../doc-translation-ir",
    "@xmldom/xmldom": "^0.8.10",
    "jszip": "^3.10.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
